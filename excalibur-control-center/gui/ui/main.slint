import { AboutSlint, Button, HorizontalBox, ListView, Slider, SpinBox, VerticalBox } from "std-widgets.slint";

export enum AppTab { main, keyboard, gpu, about }
export enum GpuMode { hybrid, discrete, uma }
export enum KeyboardZoneSelection { all, left, middle, right, bias }
export struct CreditItem {
    label: string,
    name: string,
    url: string,
}

export component MainWindow inherits Window {
    in property <string> status: "";
    in property <string> active_zone: "all";
    in property <string> zones_summary: "";
    in property <string> gpu_mode: "unknown";
    in property <string> app_version: "";
    out property <[string]> main_items: [
        "Linux control center for Casper Excalibur laptops.",
        "Origin: Linux port of Casper Excalibur Control Center behavior.",
        "Features: keyboard RGB zones, brightness control, GPU mode control, and driver-backed hardware state.",
        "Driver: casper-wmi, based on Mustafa Eksi's Casper WMI work.",
        "Current GPU mode: " + root.gpu_mode,
    ];
    out property <[CreditItem]> credit_items: [
        { label: "App author", name: "Mert Kurttutan", url: "https://github.com/mert-kurttutan" },
        { label: "Driver author", name: "Mustafa Eksi", url: "https://github.com/Mustafa-eksi" },
        { label: "Source code", name: "cecc-linux", url: "https://github.com/mert-kurttutan/cecc-linux" },
    ];
    in-out property <AppTab> active_tab: AppTab.main;
    in-out property <int> brightness: 0;
    in-out property <float> brightness_slider: 0;
    in-out property <int> red: 255;
    in-out property <int> green: 255;
    in-out property <int> blue: 255;
    in-out property <float> color_hue: 0;
    in-out property <float> color_saturation: 1;
    in-out property <float> color_value: 1;
    in-out property <color> picker_base_color: #ff0000;
    in-out property <color> selected_color: #ff0000;

    callback refresh();
    callback select_tab(AppTab);
    callback select_zone(KeyboardZoneSelection);
    callback set_gpu_mode(GpuMode);
    callback brightness_edited(int);
    callback brightness_slider_changed(float);
    callback apply_brightness();
    callback color_hue_changed(float);
    callback color_sv_changed(float, float);
    callback apply_color();

    preferred-width: 980px;
    preferred-height: 640px;
    default-font-size: 18px;
    title: "Excalibur Control Center";

    HorizontalBox {
        spacing: 16px;

        Rectangle {
            width: 180px;
            vertical-stretch: 1;
            background: #111820;

            VerticalBox {
                spacing: 10px;
                padding: 12px;

                Text {
                    horizontal-alignment: center;
                    text: "Excalibur";
                }
                Button { text: "Main"; clicked => { root.select_tab(AppTab.main); } }
                Button { text: "Keyboard"; clicked => { root.select_tab(AppTab.keyboard); } }
                Button { text: "GPU"; clicked => { root.select_tab(AppTab.gpu); } }
                Button { text: "About"; clicked => { root.select_tab(AppTab.about); } }
                Rectangle { vertical-stretch: 1; }
                Button { text: "Refresh"; clicked => { root.refresh(); } }
            }
        }

        VerticalBox {
            horizontal-stretch: 1;
            spacing: 12px;

            HorizontalBox {
                height: 48px;
                horizontal-stretch: 1;
                alignment: center;

                Rectangle {
                    preferred-width: 360px;
                    max-width: 360px;
                    height: 48px;
                    horizontal-stretch: 1;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #2f3a46;
                    background: #f2f5f7;

                    Text {
                        x: 12px;
                        width: max(parent.width - 24px, 0px);
                        height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                        text: "Excalibur Control Center";
                        color: #2f3a46;
                    }
                }
            }
            // Text { text: root.status; }

            if root.active_tab == AppTab.main : VerticalBox {
                horizontal-stretch: 1;
                spacing: 0px;

                Rectangle {
                    horizontal-stretch: 1;

                    ListView {
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                        vertical-scrollbar-policy: ScrollBarPolicy.always-off;

                        for item in root.main_items: HorizontalBox {
                            padding: 0px;

                            Text {
                                text: "- " + item;
                            }
                        }
                    }
                }
            }

            if root.active_tab == AppTab.keyboard : VerticalBox {
                spacing: 12px;

                HorizontalBox {
                    spacing: 8px;
                    Button { text: "All"; clicked => { root.select_zone(KeyboardZoneSelection.all); } }
                    Button { text: "Left"; clicked => { root.select_zone(KeyboardZoneSelection.left); } }
                    Button { text: "Middle"; clicked => { root.select_zone(KeyboardZoneSelection.middle); } }
                    Button { text: "Right"; clicked => { root.select_zone(KeyboardZoneSelection.right); } }
                    Button { text: "Bias"; clicked => { root.select_zone(KeyboardZoneSelection.bias); } }
                }

                Text { text: "Selected: " + root.active_zone; }

                HorizontalBox {
                    spacing: 8px;
                    Text { text: "Brightness"; }
                    Slider {
                        minimum: 0;
                        maximum: 2;
                        value <=> root.brightness_slider;
                        changed(value) => { root.brightness_slider_changed(value); }
                    }
                    SpinBox {
                        minimum: 0;
                        maximum: 2;
                        value <=> root.brightness;
                        edited(value) => { root.brightness_edited(value); }
                    }
                    Button { text: "Apply brightness"; clicked => { root.apply_brightness(); } }
                }

                VerticalBox {
                    spacing: 8px;
                    Text { text: "Color"; }

                    hue_bar := Rectangle {
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: #2f3a46;
                        background: @linear-gradient(90deg, #ff0000 0%, #ffff00 16.6%, #00ff00 33.3%, #00ffff 50%, #0000ff 66.6%, #ff00ff 83.3%, #ff0000 100%);

                        hue_bar_touch := TouchArea {
                            clicked => { root.color_hue_changed(hue_bar_touch.mouse_x / hue_bar.width); }
                            moved => { root.color_hue_changed(hue_bar_touch.mouse_x / hue_bar.width); }
                        }

                        Rectangle {
                            x: root.color_hue / 360 * hue_bar.width - 5px;
                            y: 0px;
                            width: 10px;
                            height: parent.height;
                            border-width: 2px;
                            border-color: white;
                            background: transparent;
                        }
                    }

                    picker_square := Rectangle {
                        height: 220px;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: #2f3a46;
                        background: root.picker_base_color;

                        Rectangle {
                            background: @linear-gradient(90deg, white, transparent);
                            border-radius: 12px;
                        }
                        Rectangle {
                            background: @linear-gradient(0deg, black, transparent);
                            border-radius: 12px;
                        }

                        picker_square_touch := TouchArea {
                            clicked => {
                                root.color_sv_changed(
                                    picker_square_touch.mouse_x / picker_square.width,
                                    picker_square_touch.mouse_y / picker_square.height
                                );
                            }
                            moved => {
                                root.color_sv_changed(
                                    picker_square_touch.mouse_x / picker_square.width,
                                    picker_square_touch.mouse_y / picker_square.height
                                );
                            }
                        }

                        Rectangle {
                            x: root.color_saturation * picker_square.width - 6px;
                            y: (1 - root.color_value) * picker_square.height - 6px;
                            width: 12px;
                            height: 12px;
                            border-radius: 6px;
                            border-width: 2px;
                            border-color: white;
                            background: transparent;
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Rectangle {
                            width: 64px;
                            height: 36px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #2f3a46;
                            background: root.selected_color;
                        }
                        Text {
                            text: "RGB: " + root.red + ", " + root.green + ", " + root.blue;
                        }
                        Button { text: "Apply color"; clicked => { root.apply_color(); } }
                    }
                }

                Text { text: "Zones"; }
                Text { text: root.zones_summary; }
            }

            if root.active_tab == AppTab.gpu : VerticalBox {
                spacing: 10px;

                Text { text: "Current GPU mode: " + root.gpu_mode; }
                HorizontalBox {
                    spacing: 8px;
                    Button { text: "Hybrid"; clicked => { root.set_gpu_mode(GpuMode.hybrid); } }
                    Button { text: "Discrete"; clicked => { root.set_gpu_mode(GpuMode.discrete); } }
                    Button { text: "UMA"; clicked => { root.set_gpu_mode(GpuMode.uma); } }
                }
                Text { text: "GPU mode changes may require reboot and matching OS graphics configuration."; }
            }

            if root.active_tab == AppTab.about : VerticalBox {
                spacing: 12px;

                Text {
                    text: "Credits";
                }

                ListView {
                    horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;

                    for credit in root.credit_items: HorizontalBox {
                        padding: 0px;
                        spacing: 8px;

                        Text { text: "- " + credit.label + ":"; }

                        Text {
                            color: #2563eb;
                            text: credit.name;
                        }

                        TouchArea {
                            clicked => { Platform.open-url(credit.url); }
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                AboutSlint {
                    height: 92px;
                }
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalBox {
                padding: 0px;
                alignment: space-between;

                Text {
                    color: #6b7280;
                    text: "Made by Mert Kurttutan";
                }

                Text {
                    color: #6b7280;
                    text: "v" + root.app_version;
                }
            }
        }
    }
}
