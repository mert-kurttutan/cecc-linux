import { AboutSlint, Button, HorizontalBox, ListView, Slider, SpinBox, VerticalBox } from "std-widgets.slint";

export enum AppTab { system_mode, display_mode, led_control, main, about }
export enum GpuMode { hybrid, discrete, uma }
export enum KeyboardZoneSelection { all, left, middle, right, bias }
enum SystemMode { office, gaming, high_performance }
export struct CreditItem {
    label: string,
    name: string,
    url: string,
}

component ControlButtonBase inherits Rectangle {
    in property <string> text: "";
    in property <bool> selected: false;
    in property <color> default-background: #2f3a46;
    in property <color> hover-background: #37516c;
    in property <color> selected-background: #2f3a46;
    in property <color> default-border-color: #2f3a46;
    in property <color> hover-border-color: #4b6987;
    in property <color> selected-border-color: #4b6987;
    in property <color> selected-text-color: white;
    in property <color> default-text-color: #a3aab3;
    callback clicked <=> touch.clicked;

    border-color: root.selected ? root.selected-border-color : (touch.has-hover ? root.hover-border-color : root.default-border-color);
    background: root.selected ? root.selected-background : (touch.has-hover ? root.hover-background : root.default-background);
    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    touch := TouchArea {
        mouse-cursor: pointer;
    }

    Text {
        x: 12px;
        width: max(parent.width - 24px, 0px);
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        text: root.text;
        color: root.selected ? root.selected-text-color : root.default-text-color;
        font-size: 16px;
    }
}

component HoverButton inherits ControlButtonBase {
    height: 40px;
    border-radius: 6px;
    border-width: 1px;
    default-background: #1f2933;
    selected-background: #2f3a46;
    default-border-color: #2f3a46;
    selected-border-color: #4b6987;
}

component SystemModeButton inherits ControlButtonBase {

    min-height: 60px;
    min-width: 120px;
    preferred-width: 120px;
    preferred-height: 60px;
    max-height: 60px;
    horizontal-stretch: 1;
    border-width: root.selected ? 1px : 0px;
    default-background: root.selected ? #2f3a46 : #151b22;
    selected-background: #2f3a46;
    hover-background: #273545;
    default-border-color: #bdc1c4;
    hover-border-color: #bdc1c4;
    selected-border-color: #bdc1c4;
}

component Hyperlink inherits Rectangle {
    in property <string> text: "";
    in property <string> url: "";

    height: 24px;
    min-width: link_text.min-width;
    preferred-width: link_text.preferred-width;
    horizontal-stretch: 0;

    link_text := Text {
        height: parent.height;
        vertical-alignment: center;
        color: touch.has-hover ? #1d4ed8 : #2563eb;
        font-weight: touch.has-hover ? 700 : 400;
        text: root.text;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { Platform.open-url(root.url); }
    }
}

component WindowControlButton inherits Rectangle {
    in property <string> text: "";
    in property <length> text-size: 28px;
    in property <length> text-y-offset: 0px;
    callback clicked <=> touch.clicked;

    width: 44px;
    height: 44px;
    border-radius: 22px;
    background: touch.has-hover ? #6d2a20 : #2f3540cc;

    Text {
        y: root.text-y-offset;
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.text;
        color: white;
        font-size: root.text-size;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
    }
}

component FanSpeedCard inherits Rectangle {
    in property <string> label: "";
    in property <string> speed: "";

    // height: 124px;
    horizontal-stretch: 1;
    background: transparent;

    HorizontalBox {
        padding: 0px;
        spacing: 8px;
        alignment: center;

        Text {
            vertical-alignment: bottom;
            overflow: elide;
            text: root.label;
        }

        Rectangle {
            width: 100px;
            height: 100px;

            Image {
                width: 100px;
                height: 100px;
                source: @image-url("assets/fan-circle.svg");
                image-fit: contain;
            }

            Text {
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
                text: root.speed;
                color: white;
                font-size: 12px;
            }
        }

    }
}

component FanSpeedSection inherits Rectangle {
    in property <string> cpu-speed: "--";
    in property <string> gpu-speed: "--";

    min-height: 180px;
    preferred-height: 180px;
    max-height: 180px;
    horizontal-stretch: 1;
    border-width: 1px;
    border-color: #2f3a46;
    background: #151b22;
    clip: true;

    Rectangle {
        x: 0px;
        y: 0px;
        width: fan_speed_title.preferred-width + 20px;
        height: 32px;
        background: #2f3a46;

        fan_speed_title := Text {
            x: 10px;
            height: 32px;
            vertical-alignment: center;
            text: "Fan Speed";
            color: white;
        }
    }

    HorizontalBox {
        x: 12px;
        y: 36px;
        width: max(parent.width - 24px, 0px);
        height: max(parent.height - 40px, 0px);
        spacing: 0px;

        FanSpeedCard {
            horizontal-stretch: 1;
            label: "CPU FAN";
            speed: root.cpu-speed;
        }

        FanSpeedCard {
            horizontal-stretch: 1;
            label: "GPU FAN";
            speed: root.gpu-speed;
        }
    }
}

component SystemModeDistributionGraph inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    clip: true;

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: parent.height;
        source: @image-url("assets/system-mode-pentagon.svg");
        image-fit: contain;
    }
}

component DisplayModeCard inherits Rectangle {
    in property <image> icon;
    in property <string> title: "";
    in property <bool> active: false;
    callback clicked <=> touch.clicked;

    min-width: 120px;
    preferred-width: 180px;
    horizontal-stretch: 1;
    height: self.width;
    border-radius: 8px;
    border-width: 1px;
    border-color: touch.has-hover ? #4b6987 : (root.active ? #f97316 : #2f3a46);
    background: touch.has-hover ? #1f2933 : #151b22;
    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Image {
            vertical-stretch: 1;
            source: root.icon;
            image-fit: contain;
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 3px;
                border-width: 1px;
                border-color: root.active ? #f97316 : #6b7280;
                background: root.active ? #f97316 : transparent;
            }

            Text {
                vertical-alignment: center;
                overflow: elide;
                text: root.title;
                color: root.active ? white : #cbd5e1;
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
    }
}

component StatusSectionHeader inherits Rectangle {
    in property <string> text: "";

    height: 34px;
    horizontal-stretch: 1;
    background: #2f3a46;

    Text {
        x: 12px;
        width: max(parent.width - 24px, 0px);
        height: parent.height;
        vertical-alignment: center;
        overflow: elide;
        text: root.text;
        color: white;
    }
}

component SensorStatRow inherits VerticalBox {
    in property <string> label: "";
    in property <string> value: "";
    in property <string> percent: "";
    in property <float> fill: 0;

    min-height: 108px;
    preferred-height: 108px;
    spacing: 8px;

    HorizontalBox {
        padding: 0px;
        spacing: 8px;

        Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: #f97316;
        }

        Text {
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
            text: root.label;
            color: white;
        }

        Text {
            vertical-alignment: center;
            text: root.value;
            color: white;
        }
    }

    Rectangle {
        height: 12px;
        horizontal-stretch: 1;
        background: #0f141a;

        Rectangle {
            x: 0px;
            width: parent.width * root.fill;
            height: parent.height;
            background: #f97316;
        }
    }

    Text {
        horizontal-alignment: end;
        text: root.percent;
        color: white;
        font-weight: 700;
    }
}

component ResourceStatRow inherits HorizontalBox {
    in property <string> label: "";
    in property <string> percent: "";
    in property <string> detail: "";
    in property <float> fill: 0;
    in property <color> accent: #f97316;

    height: 96px;
    spacing: 14px;
    padding: 0px;

    Rectangle {
        width: 72px;
        height: 72px;
        border-radius: 36px;
        border-width: 6px;
        border-color: root.accent;
        background: transparent;

        Rectangle {
            x: 16px;
            y: 16px;
            width: 40px;
            height: 40px;
            border-radius: 20px;
            background: #2f3a46;
        }
    }

    VerticalBox {
        vertical-stretch: 1;
        spacing: 2px;
        alignment: center;

        Text {
            text: root.label;
            color: white;
        }

        Text {
            text: root.percent;
            color: white;
            font-size: 26px;
            font-weight: 700;
        }

        Text {
            text: root.detail;
            color: #a3aab3;
            font-size: 14px;
        }
    }
}

component HardwareStatsColumn inherits Rectangle {
    in property <string> cpu-frequency: "--";
    in property <string> cpu-load-percent: "--";
    in property <float> cpu-load-fill: 0;
    in property <string> gpu-frequency: "--";
    in property <string> gpu-load-percent: "--";
    in property <float> gpu-load-fill: 0;
    in property <string> memory-usage: "--";
    in property <string> memory-percent: "--";
    in property <float> memory-fill: 0;
    in property <string> storage-usage: "--";
    in property <string> storage-percent: "--";
    in property <float> storage-fill: 0;

    min-width: 280px;
    preferred-width: 280px;
    max-width: 280px;
    vertical-stretch: 1;
    background: #151b22;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        StatusSectionHeader { text: "CPU stats & GPU stats"; }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: #10161d;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                SensorStatRow {
                    label: "CPU";
                    value: root.cpu-frequency;
                    percent: root.cpu-load-percent;
                    fill: root.cpu-load-fill;
                }

                SensorStatRow {
                    label: "GPU";
                    value: root.gpu-frequency;
                    percent: root.gpu-load-percent;
                    fill: root.gpu-load-fill;
                }
            }
        }

        StatusSectionHeader { text: "Memory & Disk"; }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: #181f27;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                ResourceStatRow {
                    label: "RAM";
                    percent: root.memory-percent;
                    detail: root.memory-usage;
                    accent: #f97316;
                    fill: root.memory-fill;
                }

                ResourceStatRow {
                    label: "SSD";
                    percent: root.storage-percent;
                    detail: root.storage-usage;
                    accent: #2563eb;
                    fill: root.storage-fill;
                }
            }
        }
    }
}

component MainTab inherits VerticalBox {
    in property <[string]> items: [];

    horizontal-stretch: 1;
    vertical-stretch: 1;
    spacing: 0px;

    Rectangle {
        horizontal-stretch: 1;
        vertical-stretch: 1;

        ListView {
            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;

            for item in root.items: HorizontalBox {
                padding: 0px;

                Text {
                    text: "- " + item;
                }
            }
        }
    }
}

component SystemModeTab inherits VerticalBox {
    in-out property <SystemMode> selected_mode: SystemMode.gaming;
    in property <string> cpu-fan-rpm: "--";
    in property <string> gpu-fan-rpm: "--";

    min-width: 460px;
    min-height: 480px;
    spacing: 6px;
    horizontal-stretch: 1;
    vertical-stretch: 1;

    Rectangle {
        min-height: 60px;
        preferred-height: 60px;
        max-height: 60px;
        horizontal-stretch: 1;
        border-width: 1px;
        border-color: #bdc1c4;

        HorizontalBox {
            x: 1px;
            y: 1px;
            width: max(parent.width - 2px, 0px);
            height: max(parent.height - 2px, 0px);
            padding: 0px;
            spacing: 0px;

            SystemModeButton {
                text: "Office Mode";
                selected: root.selected_mode == SystemMode.office;
                clicked => { root.selected_mode = SystemMode.office; }
            }

            SystemModeButton {
                text: "Gaming";
                selected: root.selected_mode == SystemMode.gaming;
                clicked => { root.selected_mode = SystemMode.gaming; }
            }

            SystemModeButton {
                text: "High Performance";
                selected: root.selected_mode == SystemMode.high_performance;
                clicked => { root.selected_mode = SystemMode.high_performance; }
            }
        }
    }

    if root.selected_mode == SystemMode.office : SystemModeDistributionGraph { }

    if root.selected_mode == SystemMode.gaming : SystemModeDistributionGraph { }

    if root.selected_mode == SystemMode.high_performance : SystemModeDistributionGraph { }

    FanSpeedSection {
        cpu-speed: root.cpu-fan-rpm;
        gpu-speed: root.gpu-fan-rpm;
    }
}

component KeyboardTab inherits VerticalBox {
    in property <string> active_zone: "";
    in property <string> zones_summary: "";
    in-out property <int> brightness: 0;
    in-out property <float> brightness_slider: 0;
    in-out property <int> red: 255;
    in-out property <int> green: 255;
    in-out property <int> blue: 255;
    in-out property <float> color_hue: 0;
    in-out property <float> color_saturation: 1;
    in-out property <float> color_value: 1;
    in-out property <color> picker_base_color: #ff0000;
    in-out property <color> selected_color: #ff0000;

    callback select_zone(KeyboardZoneSelection);
    callback brightness_edited(int);
    callback brightness_slider_changed(float);
    callback apply_brightness();
    callback color_hue_changed(float);
    callback color_sv_changed(float, float);
    callback apply_color();

    vertical-stretch: 1;
    spacing: 12px;

    HorizontalBox {
        spacing: 8px;
        Button { text: "All"; clicked => { root.select_zone(KeyboardZoneSelection.all); } }
        Button { text: "Left"; clicked => { root.select_zone(KeyboardZoneSelection.left); } }
        Button { text: "Middle"; clicked => { root.select_zone(KeyboardZoneSelection.middle); } }
        Button { text: "Right"; clicked => { root.select_zone(KeyboardZoneSelection.right); } }
        Button { text: "Bias"; clicked => { root.select_zone(KeyboardZoneSelection.bias); } }
    }

    Text { text: "Selected: " + root.active_zone; }

    HorizontalBox {
        spacing: 8px;
        Text { text: "Brightness"; }
        Slider {
            minimum: 0;
            maximum: 2;
            step: 1;
            value <=> root.brightness_slider;
            changed(value) => { root.brightness_slider_changed(value); }
        }
        SpinBox {
            minimum: 0;
            maximum: 2;
            value <=> root.brightness;
            edited(value) => { root.brightness_edited(value); }
        }
        Button { text: "Apply brightness"; clicked => { root.apply_brightness(); } }
    }

    VerticalBox {
        spacing: 8px;
        Text { text: "Color"; }

        hue_bar := Rectangle {
            height: 18px;
            border-radius: 9px;
            border-width: 1px;
            border-color: #2f3a46;
            background: @linear-gradient(90deg, #ff0000 0%, #ffff00 16.6%, #00ff00 33.3%, #00ffff 50%, #0000ff 66.6%, #ff00ff 83.3%, #ff0000 100%);

            hue_bar_touch := TouchArea {
                clicked => { root.color_hue_changed(hue_bar_touch.mouse_x / hue_bar.width); }
                moved => { root.color_hue_changed(hue_bar_touch.mouse_x / hue_bar.width); }
            }

            Rectangle {
                x: root.color_hue / 360 * hue_bar.width - 5px;
                y: 0px;
                width: 10px;
                height: parent.height;
                border-width: 2px;
                border-color: white;
                background: transparent;
            }
        }

        picker_square := Rectangle {
            height: 220px;
            border-radius: 12px;
            border-width: 1px;
            border-color: #2f3a46;
            background: root.picker_base_color;

            Rectangle {
                background: @linear-gradient(90deg, white, transparent);
                border-radius: 12px;
            }
            Rectangle {
                background: @linear-gradient(0deg, black, transparent);
                border-radius: 12px;
            }

            picker_square_touch := TouchArea {
                clicked => {
                    root.color_sv_changed(
                        picker_square_touch.mouse_x / picker_square.width,
                        picker_square_touch.mouse_y / picker_square.height
                    );
                }
                moved => {
                    root.color_sv_changed(
                        picker_square_touch.mouse_x / picker_square.width,
                        picker_square_touch.mouse_y / picker_square.height
                    );
                }
            }

            Rectangle {
                x: root.color_saturation * picker_square.width - 6px;
                y: (1 - root.color_value) * picker_square.height - 6px;
                width: 12px;
                height: 12px;
                border-radius: 6px;
                border-width: 2px;
                border-color: white;
                background: transparent;
            }
        }

        HorizontalBox {
            spacing: 12px;
            Rectangle {
                width: 64px;
                height: 36px;
                border-radius: 8px;
                border-width: 1px;
                border-color: #2f3a46;
                background: root.selected_color;
            }
            Text {
                text: "RGB: " + root.red + ", " + root.green + ", " + root.blue;
            }
            Button { text: "Apply color"; clicked => { root.apply_color(); } }
        }
    }

    Text { text: "Zones"; }
    Text { text: root.zones_summary; }
}

component GpuTab inherits VerticalBox {
    in property <string> gpu_mode: "unknown";
    in property <string> cpu-fan-rpm: "--";
    in property <string> gpu-fan-rpm: "--";
    callback set_gpu_mode(GpuMode);

    min-width: 460px;
    min-height: 430px;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    spacing: 10px;

    Rectangle {
        horizontal-stretch: 1;
        vertical-stretch: 1;

        VerticalBox {
            width: parent.width;
            height: parent.height;
            spacing: 10px;
            alignment: center;

            HorizontalBox {
                spacing: 8px;
                DisplayModeCard {
                    icon: @image-url("assets/gpu-discrete-mode.svg");
                    title: "Discrete";
                    active: root.gpu_mode == "discrete";
                    clicked => { root.set_gpu_mode(GpuMode.discrete); }
                }
                DisplayModeCard {
                    icon: @image-url("assets/gpu-hybrid-mode.svg");
                    title: "Hybrid";
                    active: root.gpu_mode == "hybrid";
                    clicked => { root.set_gpu_mode(GpuMode.hybrid); }
                }
                DisplayModeCard {
                    icon: @image-url("assets/gpu-uma-mode.svg");
                    title: "UMA";
                    active: root.gpu_mode == "uma";
                    clicked => { root.set_gpu_mode(GpuMode.uma); }
                }
            }
            Text { text: "GPU mode changes may require reboot and matching OS graphics configuration."; }
        }
    }

    FanSpeedSection {
        cpu-speed: root.cpu-fan-rpm;
        gpu-speed: root.gpu-fan-rpm;
    }
}

component AboutTab inherits VerticalBox {
    in property <[CreditItem]> credit_items: [];

    vertical-stretch: 1;
    spacing: 12px;

    Text {
        text: "Credits";
    }

    ListView {
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;

        for credit in root.credit_items: HorizontalBox {
            padding: 0px;
            spacing: 4px;
            alignment: start;

            Text {
                horizontal-stretch: 0;
                text: "- " + credit.label + ":";
            }

            Hyperlink { text: credit.name; url: credit.url; }
        }
    }

    Rectangle { vertical-stretch: 1; }

    AboutSlint {
        height: 128px;
    }
}

export component MainWindow inherits Window {
    in property <string> status: "";
    in property <string> active_zone: "all";
    in property <string> zones_summary: "";
    in property <string> gpu_mode: "unknown";
    in property <string> app_version: "";
    in property <string> cpu_fan_rpm: "--";
    in property <string> gpu_fan_rpm: "--";
    in property <string> cpu_frequency: "--";
    in property <string> cpu_load_percent: "--";
    in property <float> cpu_load_fill: 0;
    in property <string> gpu_frequency: "--";
    in property <string> gpu_load_percent: "--";
    in property <float> gpu_load_fill: 0;
    in property <string> memory_usage: "--";
    in property <string> memory_percent: "--";
    in property <float> memory_fill: 0;
    in property <string> storage_usage: "--";
    in property <string> storage_percent: "--";
    in property <float> storage_fill: 0;
    out property <[string]> main_items: [
        "Linux control center for Casper Excalibur laptops.",
        "Origin: Linux port of Casper Excalibur Control Center behavior.",
        "Features: keyboard RGB zones, brightness control, GPU mode control, and driver-backed hardware state.",
        "Driver: casper-wmi, based on Mustafa Eksi's Casper WMI work.",
        "Current GPU mode: " + root.gpu_mode,
    ];
    out property <[CreditItem]> credit_items: [
        { label: "App author", name: "Mert Kurttutan", url: "https://github.com/mert-kurttutan" },
        { label: "Driver author", name: "Mustafa Eksi", url: "https://github.com/Mustafa-eksi" },
        { label: "Source code", name: "cecc-linux", url: "https://github.com/mert-kurttutan/cecc-linux" },
    ];
    in-out property <AppTab> active_tab: AppTab.system_mode;
    in-out property <int> brightness: 0;
    in-out property <float> brightness_slider: 0;
    in-out property <int> red: 255;
    in-out property <int> green: 255;
    in-out property <int> blue: 255;
    in-out property <float> color_hue: 0;
    in-out property <float> color_saturation: 1;
    in-out property <float> color_value: 1;
    in-out property <color> picker_base_color: #ff0000;
    in-out property <color> selected_color: #ff0000;

    callback refresh();
    callback select_tab(AppTab);
    callback select_zone(KeyboardZoneSelection);
    callback set_gpu_mode(GpuMode);
    callback brightness_edited(int);
    callback brightness_slider_changed(float);
    callback apply_brightness();
    callback color_hue_changed(float);
    callback color_sv_changed(float, float);
    callback apply_color();
    callback start_drag_window();

    preferred-width: 1180px;
    preferred-height: 840px;
    min-width: 1180px;
    min-height: 840px;
    default-font-size: 18px;
    title: "Excalibur Control Center";
    no-frame: true;
    resize-border-width: 6px;

    Timer {
        interval: 1s;
        running: root.active_tab == AppTab.system_mode || root.active_tab == AppTab.display_mode;
        triggered => {
            root.refresh();
        }
    }

    VerticalBox {
        spacing: 0px;

        Rectangle {
            height: 72px;
            horizontal-stretch: 1;
            background: @linear-gradient(90deg, #202631 0%, #4a342f 42%, #9a3b14 100%);

            HorizontalBox {
                x: 28px;
                y: 0px;
                width: max(parent.width - 56px, 0px);
                height: parent.height;
                spacing: 16px;

                Text {
                    vertical-alignment: center;
                    text: "EXCALIBUR CONTROL CENTER";
                    color: white;
                    font-size: 26px;
                    font-weight: 700;
                }

                Rectangle { horizontal-stretch: 1; }

                Rectangle {
                    width: 44px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        text: "-";
                        text-y-offset: -1px;
                        clicked => { root.minimized = true; }
                    }
                }

                Rectangle {
                    width: 44px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        text: "□";
                        text-size: 16px;
                        text-y-offset: 1px;
                        clicked => { root.maximized = !root.maximized; }
                    }
                }

                Rectangle {
                    width: 44px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        text: "x";
                        text-y-offset: -2px;
                        clicked => { root.close(); }
                    }
                }
            }

            title_bar_touch := TouchArea {
                width: max(parent.width - 220px, 0px);
                height: parent.height;
                changed pressed => {
                    if (self.pressed) {
                        root.start_drag_window();
                    }
                }
                double-clicked => { root.maximized = !root.maximized; }
            }
        }

        Rectangle {
            vertical-stretch: 1;

            HorizontalBox {
                spacing: 0px;

                Rectangle {
                    width: 180px;
                    vertical-stretch: 1;
                    background: #111820;

                    VerticalBox {
                        spacing: 10px;
                        padding: 12px;

                        HoverButton { text: "System Mode"; selected: root.active_tab == AppTab.system_mode; clicked => { root.select_tab(AppTab.system_mode); } }
                        HoverButton { text: "Display Mode"; selected: root.active_tab == AppTab.display_mode; clicked => { root.select_tab(AppTab.display_mode); } }
                        HoverButton { text: "LED Control"; selected: root.active_tab == AppTab.led_control; clicked => { root.select_tab(AppTab.led_control); } }
                        HoverButton { text: "Main"; selected: root.active_tab == AppTab.main; clicked => { root.select_tab(AppTab.main); } }
                        HoverButton { text: "About"; selected: root.active_tab == AppTab.about; clicked => { root.select_tab(AppTab.about); } }
                        Rectangle { vertical-stretch: 1; }
                        HoverButton { text: "Refresh"; clicked => { root.refresh(); } }
                    }
                }

                VerticalBox {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        tab_content := Rectangle {
                            x: 0px;
                            y: 0px;
                            width: min(parent.width, 1728px);
                            height: min(parent.height, 1080px);

                            if root.active_tab == AppTab.system_mode : HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                spacing: 8px;

                                SystemModeTab {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    cpu-fan-rpm: root.cpu_fan_rpm;
                                    gpu-fan-rpm: root.gpu_fan_rpm;
                                }

                                HardwareStatsColumn {
                                    cpu-frequency: root.cpu_frequency;
                                    cpu-load-percent: root.cpu_load_percent;
                                    cpu-load-fill: root.cpu_load_fill;
                                    gpu-frequency: root.gpu_frequency;
                                    gpu-load-percent: root.gpu_load_percent;
                                    gpu-load-fill: root.gpu_load_fill;
                                    memory-usage: root.memory_usage;
                                    memory-percent: root.memory_percent;
                                    memory-fill: root.memory_fill;
                                    storage-usage: root.storage_usage;
                                    storage-percent: root.storage_percent;
                                    storage-fill: root.storage_fill;
                                }
                            }

                            if root.active_tab == AppTab.main : MainTab {
                                width: parent.width;
                                height: parent.height;
                                items: root.main_items;
                            }

                            if root.active_tab == AppTab.led_control : KeyboardTab {
                                width: parent.width;
                                height: parent.height;
                                active_zone: root.active_zone;
                                zones_summary: root.zones_summary;
                                brightness <=> root.brightness;
                                brightness_slider <=> root.brightness_slider;
                                red <=> root.red;
                                green <=> root.green;
                                blue <=> root.blue;
                                color_hue <=> root.color_hue;
                                color_saturation <=> root.color_saturation;
                                color_value <=> root.color_value;
                                picker_base_color <=> root.picker_base_color;
                                selected_color <=> root.selected_color;

                                select_zone(zone) => { root.select_zone(zone); }
                                brightness_edited(value) => { root.brightness_edited(value); }
                                brightness_slider_changed(value) => { root.brightness_slider_changed(value); }
                                apply_brightness => { root.apply_brightness(); }
                                color_hue_changed(value) => { root.color_hue_changed(value); }
                                color_sv_changed(saturation, value) => { root.color_sv_changed(saturation, value); }
                                apply_color => { root.apply_color(); }
                            }

                            if root.active_tab == AppTab.display_mode : HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                spacing: 8px;

                                GpuTab {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    gpu_mode: root.gpu_mode;
                                    cpu-fan-rpm: root.cpu_fan_rpm;
                                    gpu-fan-rpm: root.gpu_fan_rpm;
                                    set_gpu_mode(mode) => { root.set_gpu_mode(mode); }
                                }

                                HardwareStatsColumn {
                                    cpu-frequency: root.cpu_frequency;
                                    cpu-load-percent: root.cpu_load_percent;
                                    cpu-load-fill: root.cpu_load_fill;
                                    gpu-frequency: root.gpu_frequency;
                                    gpu-load-percent: root.gpu_load_percent;
                                    gpu-load-fill: root.gpu_load_fill;
                                    memory-usage: root.memory_usage;
                                    memory-percent: root.memory_percent;
                                    memory-fill: root.memory_fill;
                                    storage-usage: root.storage_usage;
                                    storage-percent: root.storage_percent;
                                    storage-fill: root.storage_fill;
                                }
                            }

                            if root.active_tab == AppTab.about : AboutTab {
                                width: parent.width;
                                height: parent.height;
                                credit_items: root.credit_items;
                            }
                        }
                    }

                    HorizontalBox {
                        padding: 0px;
                        alignment: space-between;

                        Text {
                            color: #6b7280;
                            text: "Made by Mert Kurttutan";
                        }

                        Text {
                            color: #6b7280;
                            text: "v" + root.app_version;
                        }
                    }
                }
            }
        }
    }
}
