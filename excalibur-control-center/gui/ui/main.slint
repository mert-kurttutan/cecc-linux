import { AboutSlint, Button, CheckBox, HorizontalBox, ListView, Slider, VerticalBox } from "std-widgets.slint";

export enum AppTab { system_mode, display_mode, led_control, about }
export enum GpuMode { hybrid, discrete, uma }
export enum KeyboardZoneSelection { all, left, middle, right, bias }
enum SystemMode { office, gaming, high_performance }
export struct CreditItem {
    label: string,
    name: string,
    url: string,
}

component ControlButtonBase inherits Rectangle {
    in property <string> text: "";
    in property <bool> selected: false;
    in property <color> default-background: #2f3a46;
    in property <color> hover-background: #37516c;
    in property <color> selected-background: #2f3a46;
    in property <color> default-border-color: #2f3a46;
    in property <color> hover-border-color: #4b6987;
    in property <color> selected-border-color: #4b6987;
    in property <color> selected-text-color: white;
    in property <color> default-text-color: #a3aab3;
    callback clicked <=> touch.clicked;

    border-color: root.selected ? root.selected-border-color : (touch.has-hover ? root.hover-border-color : root.default-border-color);
    background: root.selected ? root.selected-background : (touch.has-hover ? root.hover-background : root.default-background);
    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    touch := TouchArea {
        mouse-cursor: pointer;
    }

    Text {
        x: 12px;
        width: max(parent.width - 24px, 0px);
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        text: root.text;
        color: root.selected ? root.selected-text-color : root.default-text-color;
        font-size: 16px;
    }
}

component HoverButton inherits ControlButtonBase {
    height: 40px;
    border-radius: 6px;
    border-width: 1px;
    default-background: #1f2933;
    selected-background: #2f3a46;
    default-border-color: #2f3a46;
    selected-border-color: #4b6987;
}

component SystemModeButton inherits ControlButtonBase {

    min-height: 60px;
    min-width: 120px;
    preferred-width: 120px;
    preferred-height: 60px;
    max-height: 60px;
    horizontal-stretch: 1;
    border-width: root.selected ? 1px : 0px;
    default-background: root.selected ? #2f3a46 : #151b22;
    selected-background: #2f3a46;
    hover-background: #273545;
    default-border-color: #bdc1c4;
    hover-border-color: #bdc1c4;
    selected-border-color: #bdc1c4;
}

component Hyperlink inherits Rectangle {
    in property <string> text: "";
    in property <string> url: "";
    in property <color> default-color: #2563eb;
    in property <color> hover-color: #1d4ed8;

    height: 24px;
    min-width: link_text.min-width;
    preferred-width: link_text.preferred-width;
    horizontal-stretch: 0;

    link_text := Text {
        height: parent.height;
        vertical-alignment: center;
        color: touch.has-hover ? root.hover-color : root.default-color;
        font-weight: touch.has-hover ? 700 : 400;
        text: root.text;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { Platform.open-url(root.url); }
    }
}

component WindowControlButton inherits Rectangle {
    in property <image> icon;
    callback clicked <=> touch.clicked;

    width: 44px;
    height: 44px;
    border-radius: 22px;
    background: touch.has-hover ? #6d2a20 : #2f3540cc;

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        source: root.icon;
    }

    touch := TouchArea {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        mouse-cursor: pointer;
    }
}

component PopupCloseButton inherits Rectangle {
    callback clicked <=> touch.clicked;

    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: touch.has-hover ? #6d2a20 : #2f3540cc;

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 12px;
        height: 12px;
        source: @image-url("assets/window-close.svg");
    }

    touch := TouchArea {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        mouse-cursor: pointer;
    }
}

component FanSpeedCard inherits Rectangle {
    in property <string> label: "";
    in property <string> speed: "";
    in property <color> default-text-color: #cbd5e1;

    // height: 124px;
    horizontal-stretch: 1;
    background: transparent;

    HorizontalBox {
        padding: 0px;
        spacing: 8px;
        alignment: center;

        Text {
            vertical-alignment: bottom;
            overflow: elide;
            text: root.label;
            color: root.default-text-color;
        }

        Rectangle {
            width: 100px;
            height: 100px;

            Image {
                width: 100px;
                height: 100px;
                source: @image-url("assets/fan-circle.svg");
                image-fit: contain;
            }

            Text {
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
                text: root.speed;
                color: white;
                font-size: 12px;
            }
        }

    }
}

component FanSpeedSection inherits Rectangle {
    in property <string> cpu-speed: "--";
    in property <string> gpu-speed: "--";
    in property <color> default-text-color: #cbd5e1;

    min-height: 180px;
    preferred-height: 180px;
    max-height: 180px;
    horizontal-stretch: 1;
    border-width: 1px;
    border-color: #2f3a46;
    background: #151b22;
    clip: true;

    Rectangle {
        x: 0px;
        y: 0px;
        width: fan_speed_title.preferred-width + 20px;
        height: 32px;
        background: #2f3a46;

        fan_speed_title := Text {
            x: 10px;
            height: 32px;
            vertical-alignment: center;
            text: "Fan Speed";
            color: white;
        }
    }

    HorizontalBox {
        x: 12px;
        y: 36px;
        width: max(parent.width - 24px, 0px);
        height: max(parent.height - 40px, 0px);
        spacing: 0px;

        FanSpeedCard {
            horizontal-stretch: 1;
            label: "CPU FAN";
            speed: root.cpu-speed;
            default-text-color: root.default-text-color;
        }

        FanSpeedCard {
            horizontal-stretch: 1;
            label: "GPU FAN";
            speed: root.gpu-speed;
            default-text-color: root.default-text-color;
        }
    }
}

component KeyboardZonePreview inherits Rectangle {
    in property <string> active-zone: "";
    in property <color> left-color: #000000;
    in property <color> middle-color: #000000;
    in property <color> right-color: #000000;
    in property <color> bias-color: #000000;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: #080a0d;
    border-width: 1px;
    border-color: #2f3a46;
    clip: true;

    deck := Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 48px, (parent.height - 48px) * 900 / 500);
        height: self.width * 500 / 900;

        Image {
            width: parent.width;
            height: parent.height;
            source: @image-url("assets/keyboard-preview.svg");
            image-fit: contain;
        }

        Rectangle {
            x: parent.width * 104 / 900;
            y: parent.height * 150 / 500;
            width: parent.width * 230 / 900;
            height: parent.height * 196 / 500;
            border-radius: 8px;
            background: root.left-color;
            opacity: 0.55;
        }

        Rectangle {
            x: parent.width * 334 / 900;
            y: parent.height * 150 / 500;
            width: parent.width * 230 / 900;
            height: parent.height * 196 / 500;
            border-radius: 8px;
            background: root.middle-color;
            opacity: 0.55;
        }

        Rectangle {
            x: parent.width * 564 / 900;
            y: parent.height * 150 / 500;
            width: parent.width * 232 / 900;
            height: parent.height * 196 / 500;
            border-radius: 8px;
            background: root.right-color;
            opacity: 0.55;
        }

        Rectangle {
            x: parent.width * 84 / 900;
            y: parent.height * 76 / 500;
            width: parent.width * 732 / 900;
            height: parent.height * 38 / 500;
            border-radius: 8px;
            background: root.bias-color;
            opacity: 0.62;
        }

        Image {
            width: parent.width;
            height: parent.height;
            source: @image-url("assets/keyboard-key-outlines.svg");
            image-fit: contain;
        }
    }
}

component SystemModeDistributionGraph inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    clip: true;

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width;
        height: parent.height;
        source: @image-url("assets/system-mode-pentagon.svg");
        image-fit: contain;
    }
}

component DisplayModeCard inherits Rectangle {
    in property <image> icon;
    in property <string> title: "";
    in property <bool> active: false;
    callback clicked <=> touch.clicked;

    min-width: 120px;
    preferred-width: 180px;
    horizontal-stretch: 1;
    height: self.width;
    border-radius: 8px;
    border-width: 1px;
    border-color: touch.has-hover ? #4b6987 : (root.active ? #f97316 : #2f3a46);
    background: touch.has-hover ? #1f2933 : #151b22;
    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Image {
            vertical-stretch: 1;
            source: root.icon;
            image-fit: contain;
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 3px;
                border-width: 1px;
                border-color: root.active ? #f97316 : #6b7280;
                background: root.active ? #f97316 : transparent;
            }

            Text {
                vertical-alignment: center;
                overflow: elide;
                text: root.title;
                color: root.active ? white : #cbd5e1;
            }
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
    }
}

component StatusSectionHeader inherits Rectangle {
    in property <string> text: "";

    height: 34px;
    horizontal-stretch: 1;
    background: #2f3a46;

    Text {
        x: 12px;
        width: max(parent.width - 24px, 0px);
        height: parent.height;
        vertical-alignment: center;
        overflow: elide;
        text: root.text;
        color: white;
    }
}

component SensorStatRow inherits VerticalBox {
    in property <string> label: "";
    in property <string> value: "";
    in property <string> percent: "";
    in property <float> fill: 0;

    min-height: 108px;
    preferred-height: 108px;
    spacing: 8px;

    HorizontalBox {
        padding: 0px;
        spacing: 8px;

        Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: #f97316;
        }

        Text {
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
            text: root.label;
            color: white;
        }

        Text {
            vertical-alignment: center;
            text: root.value;
            color: white;
        }
    }

    Rectangle {
        height: 12px;
        horizontal-stretch: 1;
        background: #0f141a;

        Rectangle {
            x: 0px;
            width: parent.width * root.fill;
            height: parent.height;
            background: #f97316;
        }
    }

    Text {
        horizontal-alignment: end;
        text: root.percent;
        color: white;
        font-weight: 700;
    }
}

component ResourceStatRow inherits HorizontalBox {
    in property <string> label: "";
    in property <string> percent: "";
    in property <string> detail: "";
    in property <float> fill: 0;
    in property <color> accent: #f97316;

    height: 96px;
    spacing: 14px;
    padding: 0px;

    Rectangle {
        width: 72px;
        height: 72px;
        border-radius: 36px;
        border-width: 6px;
        border-color: root.accent;
        background: transparent;

        Rectangle {
            x: 16px;
            y: 16px;
            width: 40px;
            height: 40px;
            border-radius: 20px;
            background: #2f3a46;
        }
    }

    VerticalBox {
        vertical-stretch: 1;
        spacing: 2px;
        alignment: center;

        Text {
            text: root.label;
            color: white;
        }

        Text {
            text: root.percent;
            color: white;
            font-size: 26px;
            font-weight: 700;
        }

        Text {
            text: root.detail;
            color: #a3aab3;
            font-size: 14px;
        }
    }
}

component HardwareStatsColumn inherits Rectangle {
    in property <string> cpu-frequency: "--";
    in property <string> cpu-load-percent: "--";
    in property <float> cpu-load-fill: 0;
    in property <string> gpu-frequency: "--";
    in property <string> gpu-load-percent: "--";
    in property <float> gpu-load-fill: 0;
    in property <string> memory-usage: "--";
    in property <string> memory-percent: "--";
    in property <float> memory-fill: 0;
    in property <string> storage-usage: "--";
    in property <string> storage-percent: "--";
    in property <float> storage-fill: 0;

    min-width: 280px;
    preferred-width: 280px;
    max-width: 280px;
    vertical-stretch: 1;
    background: #151b22;

    VerticalBox {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        StatusSectionHeader { text: "CPU stats & GPU stats"; }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: #10161d;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                SensorStatRow {
                    label: "CPU";
                    value: root.cpu-frequency;
                    percent: root.cpu-load-percent;
                    fill: root.cpu-load-fill;
                }

                SensorStatRow {
                    label: "GPU";
                    value: root.gpu-frequency;
                    percent: root.gpu-load-percent;
                    fill: root.gpu-load-fill;
                }
            }
        }

        StatusSectionHeader { text: "Memory & Disk"; }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: #181f27;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                ResourceStatRow {
                    label: "RAM";
                    percent: root.memory-percent;
                    detail: root.memory-usage;
                    accent: #f97316;
                    fill: root.memory-fill;
                }

                ResourceStatRow {
                    label: "SSD";
                    percent: root.storage-percent;
                    detail: root.storage-usage;
                    accent: #2563eb;
                    fill: root.storage-fill;
                }
            }
        }
    }
}

component SystemModeTab inherits VerticalBox {
    in-out property <SystemMode> selected_mode: SystemMode.gaming;
    in property <string> cpu-fan-rpm: "--";
    in property <string> gpu-fan-rpm: "--";
    in property <color> default-text-color: #cbd5e1;

    min-width: 460px;
    min-height: 480px;
    spacing: 6px;
    horizontal-stretch: 1;
    vertical-stretch: 1;

    Rectangle {
        min-height: 60px;
        preferred-height: 60px;
        max-height: 60px;
        horizontal-stretch: 1;
        border-width: 1px;
        border-color: #bdc1c4;

        HorizontalBox {
            x: 1px;
            y: 1px;
            width: max(parent.width - 2px, 0px);
            height: max(parent.height - 2px, 0px);
            padding: 0px;
            spacing: 0px;

            SystemModeButton {
                text: "Office Mode";
                selected: root.selected_mode == SystemMode.office;
                clicked => { root.selected_mode = SystemMode.office; }
            }

            SystemModeButton {
                text: "Gaming";
                selected: root.selected_mode == SystemMode.gaming;
                clicked => { root.selected_mode = SystemMode.gaming; }
            }

            SystemModeButton {
                text: "High Performance";
                selected: root.selected_mode == SystemMode.high_performance;
                clicked => { root.selected_mode = SystemMode.high_performance; }
            }
        }
    }

    if root.selected_mode == SystemMode.office : SystemModeDistributionGraph { }

    if root.selected_mode == SystemMode.gaming : SystemModeDistributionGraph { }

    if root.selected_mode == SystemMode.high_performance : SystemModeDistributionGraph { }

    FanSpeedSection {
        cpu-speed: root.cpu-fan-rpm;
        gpu-speed: root.gpu-fan-rpm;
        default-text-color: root.default-text-color;
    }
}

component KeyboardTab inherits VerticalBox {
    in property <string> active_zone: "";
    in-out property <int> brightness: 0;
    in-out property <float> brightness_slider: 0;
    in-out property <int> red: 255;
    in-out property <int> green: 255;
    in-out property <int> blue: 255;
    in-out property <float> color_hue: 0;
    in-out property <float> color_saturation: 1;
    in property <color> applied_left_color: #000000;
    in property <color> applied_middle_color: #000000;
    in property <color> applied_right_color: #000000;
    in property <color> applied_bias_color: #000000;

    callback select_zone(KeyboardZoneSelection);
    callback brightness_slider_changed(float);
    callback color_wheel_changed(float, float);
    callback apply_led_settings();

    vertical-stretch: 1;
    horizontal-stretch: 1;

    HorizontalBox {
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: #050608;

            VerticalBox {
                padding: 28px;
                spacing: 18px;

                HorizontalBox {
                    spacing: 28px;
                    alignment: center;

                    SystemModeButton {
                        text: "Zone A";
                        selected: root.active_zone == "left";
                        clicked => { root.select_zone(KeyboardZoneSelection.left); }
                    }
                    SystemModeButton {
                        text: "Zone B";
                        selected: root.active_zone == "middle";
                        clicked => { root.select_zone(KeyboardZoneSelection.middle); }
                    }
                    SystemModeButton {
                        text: "Zone C";
                        selected: root.active_zone == "right";
                        clicked => { root.select_zone(KeyboardZoneSelection.right); }
                    }
                    SystemModeButton {
                        text: "Trunk";
                        selected: root.active_zone == "bias";
                        clicked => { root.select_zone(KeyboardZoneSelection.bias); }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    KeyboardZonePreview {
                        active-zone: root.active_zone;
                        left-color: root.applied_left_color;
                        middle-color: root.applied_middle_color;
                        right-color: root.applied_right_color;
                        bias-color: root.applied_bias_color;
                    }
                }
            }
        }

        Rectangle {
            min-width: 280px;
            preferred-width: 280px;
            max-width: 280px;
            vertical-stretch: 1;
            background: #1b1f26;
            border-width: 1px;
            border-color: #2f3a46;

            VerticalBox {
                padding: 18px;
                spacing: 14px;

                HorizontalBox {
                    spacing: 8px;

                    Button {
                        text: "LED on/off";
                        clicked => { root.apply_led_settings(); }
                    }

                    CheckBox {
                        text: "Select all";
                        checked: root.active_zone == "all";
                        toggled => {
                            root.select_zone(self.checked ? KeyboardZoneSelection.all : KeyboardZoneSelection.left);
                        }
                    }
                }

                Rectangle {
                    height: 116px;
                    horizontal-stretch: 1;

                    VerticalBox {
                        spacing: 8px;

                        Button { text: "Static"; clicked => { root.apply_led_settings(); } }
                        Button { text: "Breathing"; }
                        Button { text: "Cycle"; }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    color_wheel := Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: min(parent.width - 28px, min(parent.height - 28px, 220px));
                        height: self.width;
                        border-radius: self.width / 2;
                        clip: true;

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: @image-url("assets/color-wheel.png");
                            image-fit: contain;
                        }

                        color_wheel_touch := TouchArea {
                            clicked => {
                                root.color_wheel_changed(
                                    color_wheel_touch.mouse_x / color_wheel.width,
                                    color_wheel_touch.mouse_y / color_wheel.height
                                );
                            }
                            moved => {
                                root.color_wheel_changed(
                                    color_wheel_touch.mouse_x / color_wheel.width,
                                    color_wheel_touch.mouse_y / color_wheel.height
                                );
                            }
                        }

                        Rectangle {
                            x: color_wheel.width / 2 + Math.cos(root.color_hue * 1deg) * min(root.color_saturation, 0.94) * color_wheel.width / 2 - 7px;
                            y: color_wheel.height / 2 + Math.sin(root.color_hue * 1deg) * min(root.color_saturation, 0.94) * color_wheel.height / 2 - 7px;
                            width: 14px;
                            height: 14px;
                            border-radius: 7px;
                            border-width: 2px;
                            border-color: black;
                            background: transparent;
                        }
                    }
                }

                Rectangle {
                    height: 136px;
                    horizontal-stretch: 1;

                    VerticalBox {
                        spacing: 10px;

                        HorizontalBox {
                            Text {
                                text: "Brightness";
                                color: white;
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: root.brightness * 50 + "%";
                                color: white;
                                font-size: 28px;
                                font-weight: 700;
                            }
                        }

                        Slider {
                            minimum: 0;
                            maximum: 2;
                            step: 1;
                            value <=> root.brightness_slider;
                            changed(value) => { root.brightness_slider_changed(value); }
                        }
                        Button { text: "Apply"; clicked => { root.apply_led_settings(); } }
                    }
                }
            }
        }
    }
}

component GpuTab inherits VerticalBox {
    in property <string> gpu_mode: "unknown";
    in property <string> display-mode-warning: "";
    in-out property <string> pending-display-mode-warning: "";
    in property <string> cpu-fan-rpm: "--";
    in property <string> gpu-fan-rpm: "--";
    in property <color> default-text-color: #cbd5e1;
    callback set_gpu_mode(GpuMode);

    min-width: 460px;
    min-height: 430px;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    spacing: 10px;

    Rectangle {
        horizontal-stretch: 1;
        vertical-stretch: 1;

        VerticalBox {
            width: parent.width;
            height: parent.height;
            spacing: 10px;
            alignment: center;

            HorizontalBox {
                spacing: 8px;
                DisplayModeCard {
                    icon: @image-url("assets/gpu-discrete-mode.svg");
                    title: "Discrete";
                    active: root.gpu_mode == "discrete";
                    clicked => {
                        if root.gpu_mode == "hybrid" || root.gpu_mode == "uma" {
                            root.pending-display-mode-warning = "Switching to Discrete mode may require a reboot. Discrete mode routes the display through the NVIDIA GPU. You have to change your OS graphics settings to an NVIDIA-only / Performance graphics profile.";
                            mode_warning_popup.show();
                        }
                        root.set_gpu_mode(GpuMode.discrete);
                    }
                }
                DisplayModeCard {
                    icon: @image-url("assets/gpu-hybrid-mode.svg");
                    title: "Hybrid";
                    active: root.gpu_mode == "hybrid";
                    clicked => {
                        if root.gpu_mode == "discrete" {
                            root.pending-display-mode-warning = "Switching away from Discrete mode may require a reboot. Hybrid mode routes the display through the integrated GPU and uses NVIDIA through PRIME/On-Demand offload. You have to change your OS graphics settings to a matching hybrid graphics profile.";
                            mode_warning_popup.show();
                        }
                        root.set_gpu_mode(GpuMode.hybrid);
                    }
                }
                DisplayModeCard {
                    icon: @image-url("assets/gpu-uma-mode.svg");
                    title: "UMA";
                    active: root.gpu_mode == "uma";
                    clicked => {
                        if root.gpu_mode == "discrete" {
                            root.pending-display-mode-warning = "Switching away from Discrete mode may require a reboot. UMA / Integrated mode uses only the integrated GPU path. You have to change your OS graphics settings to a matching integrated graphics profile.";
                            mode_warning_popup.show();
                        }
                        root.set_gpu_mode(GpuMode.uma);
                    }
                }
            }
        }
    }

    mode_warning_popup := PopupWindow {
        x: (root.width - self.width) / 2;
        y: 36px;
        width: min(root.width - 48px, 560px);
        height: 190px;
        close-policy: close-on-click-outside;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: #151b22;
            border-width: 1px;
            border-color: #f97316;
            border-radius: 8px;

            Rectangle {
                width: parent.width;
                height: parent.height;

                Text {
                    x: 28px;
                    y: 26px;
                    width: parent.width - 56px;
                    height: parent.height - 52px;
                    text: root.pending-display-mode-warning;
                    color: root.default-text-color;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                PopupCloseButton {
                    x: parent.width - self.width - 8px;
                    y: 8px;
                    clicked => { mode_warning_popup.close(); }
                }
            }
        }
    }

    FanSpeedSection {
        cpu-speed: root.cpu-fan-rpm;
        gpu-speed: root.gpu-fan-rpm;
        default-text-color: root.default-text-color;
    }
}

component AboutTab inherits VerticalBox {
    in property <[string]> items: [];
    in property <[CreditItem]> credit_items: [];
    in property <color> default-text-color: #cbd5e1;

    vertical-stretch: 1;
    spacing: 12px;

    Text {
        text: "About";
        color: root.default-text-color;
    }

    ListView {
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        height: 160px;

        for item in root.items: HorizontalBox {
            padding: 0px;
            x: 16px;
            width: max(parent.width - 16px, 0px);

            Text {
                text: "- " + item;
                color: root.default-text-color;
            }
        }
    }

    Text {
        text: "Credits";
        color: root.default-text-color;
    }

    ListView {
        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;

        for credit in root.credit_items: HorizontalBox {
            padding: 0px;
            x: 16px;
            width: max(parent.width - 16px, 0px);
            spacing: 4px;
            alignment: start;

            Text {
                horizontal-stretch: 0;
                text: "- " + credit.label + ":";
                color: root.default-text-color;
            }

            Hyperlink { text: credit.name; url: credit.url; }
        }
    }

    Text {
        text: "Donation";
        color: root.default-text-color;
    }

    HorizontalBox {
        padding: 0px;
        x: 16px;
        width: max(parent.width - 16px, 0px);
        spacing: 4px;
        alignment: start;

        Text {
            horizontal-stretch: 0;
            text: "- Support development:";
            color: root.default-text-color;
        }

        Hyperlink {
            text: "GitHub Sponsors";
            url: "https://github.com/sponsors/mert-kurttutan";
        }
    }

    Rectangle { vertical-stretch: 1; }

    AboutSlint {
        height: 128px;
    }
}

export component MainWindow inherits Window {
    in property <string> status: "";
    in property <string> active_zone: "all";
    in property <string> gpu_mode: "unknown";
    in property <string> display_mode_warning: "";
    in property <string> app_version: "";
    in property <string> cpu_fan_rpm: "--";
    in property <string> gpu_fan_rpm: "--";
    in property <string> cpu_frequency: "--";
    in property <string> cpu_load_percent: "--";
    in property <float> cpu_load_fill: 0;
    in property <string> gpu_frequency: "--";
    in property <string> gpu_load_percent: "--";
    in property <float> gpu_load_fill: 0;
    in property <string> memory_usage: "--";
    in property <string> memory_percent: "--";
    in property <float> memory_fill: 0;
    in property <string> storage_usage: "--";
    in property <string> storage_percent: "--";
    in property <float> storage_fill: 0;
    out property <[string]> main_items: [
        "Linux control center for Casper Excalibur laptops.",
        "Origin: Linux port of Casper Excalibur Control Center behavior.",
        "Features: keyboard RGB zones, brightness control, GPU mode control, and driver-backed hardware state.",
        "Driver: casper-wmi, based on Mustafa Eksi's Casper WMI work.",
        "Current GPU mode: " + root.gpu_mode,
    ];
    out property <[CreditItem]> credit_items: [
        { label: "App author", name: "Mert Kurttutan", url: "https://github.com/mert-kurttutan" },
        { label: "Author for original driver code", name: "Mustafa Eksi", url: "https://github.com/Mustafa-eksi" },
        { label: "Source code", name: "cecc-linux", url: "https://github.com/mert-kurttutan/cecc-linux" },
    ];
    in-out property <AppTab> active_tab: AppTab.system_mode;
    in-out property <int> brightness: 0;
    in-out property <float> brightness_slider: 0;
    in-out property <int> red: 255;
    in-out property <int> green: 255;
    in-out property <int> blue: 255;
    in-out property <float> color_hue: 0;
    in-out property <float> color_saturation: 1;
    in property <color> applied_left_color: #000000;
    in property <color> applied_middle_color: #000000;
    in property <color> applied_right_color: #000000;
    in property <color> applied_bias_color: #000000;
    in property <color> app_background_color: #0b0f14;
    in property <color> app_text_color: #cbd5e1;
    in-out property <bool> suppress_led_edit_events: false;
    in-out property <bool> system_mode_auto_refresh_enabled: true;
    in-out property <bool> display_mode_auto_refresh_enabled: true;
    in-out property <bool> led_control_auto_refresh_enabled: true;

    callback refresh();
    callback select_tab(AppTab);
    callback select_zone(KeyboardZoneSelection);
    callback set_gpu_mode(GpuMode);
    callback brightness_slider_changed(float);
    callback color_wheel_changed(float, float);
    callback apply_led_settings();
    callback start_drag_window();

    preferred-width: 1180px;
    preferred-height: 840px;
    min-width: 1180px;
    min-height: 840px;
    default-font-size: 18px;
    title: "Excalibur Control Center";
    no-frame: true;
    resize-border-width: 6px;
    background: root.app_background_color;

    Timer {
        interval: root.active_tab == AppTab.led_control ? 500ms : 1s;
        running: (root.active_tab == AppTab.system_mode && root.system_mode_auto_refresh_enabled)
            || (root.active_tab == AppTab.display_mode && root.display_mode_auto_refresh_enabled)
            || (root.active_tab == AppTab.led_control && root.led_control_auto_refresh_enabled);
        triggered => {
            root.refresh();
        }
    }

    VerticalBox {
        spacing: 0px;

        Rectangle {
            height: 56px;
            horizontal-stretch: 1;
            background: @linear-gradient(90deg, #202631 0%, #4a342f 42%, #9a3b14 100%);

            TouchArea {
                width: max(parent.width - 160px, 0px);
                height: parent.height;
                changed pressed => {
                    if (self.pressed) {
                        root.start_drag_window();
                    }
                }
                double-clicked => {
                    root.maximized = !root.maximized;
                }
            }

            titlebar_content := HorizontalBox {
                x: 28px;
                y: 0px;
                width: max(parent.width - 28px, 0px);
                height: parent.height;
                spacing: 8px;

                Text {
                    vertical-alignment: center;
                    text: "EXCALIBUR CONTROL CENTER";
                    color: white;
                    font-size: 26px;
                    font-weight: 700;
                }

                drag_area := Rectangle {
                    horizontal-stretch: 1;
                    height: parent.height;
                }

                Rectangle {
                    width: 40px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        icon: @image-url("assets/window-minimize.svg");
                        clicked => { root.minimized = true; }
                    }
                }

                Rectangle {
                    width: 40px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        icon: @image-url("assets/window-maximize.svg");
                        clicked => { root.maximized = !root.maximized; }
                    }
                }

                Rectangle {
                    width: 40px;
                    height: parent.height;

                    WindowControlButton {
                        y: (parent.height - self.height) / 2 - 6px;
                        icon: @image-url("assets/window-close.svg");
                        clicked => { root.close(); }
                    }
                }
            }

        }

        Rectangle {
            vertical-stretch: 1;
            background: root.app_background_color;

            HorizontalBox {
                spacing: 0px;

                Rectangle {
                    width: 180px;
                    vertical-stretch: 1;
                    background: #111820;

                    VerticalBox {
                        spacing: 10px;
                        padding: 12px;

                        HoverButton { text: "System Mode"; selected: root.active_tab == AppTab.system_mode; clicked => { root.select_tab(AppTab.system_mode); } }
                        HoverButton { text: "Display Mode"; selected: root.active_tab == AppTab.display_mode; clicked => { root.select_tab(AppTab.display_mode); } }
                        HoverButton { text: "LED Control"; selected: root.active_tab == AppTab.led_control; clicked => { root.select_tab(AppTab.led_control); } }
                        HoverButton { text: "About"; selected: root.active_tab == AppTab.about; clicked => { root.select_tab(AppTab.about); } }
                        Rectangle { vertical-stretch: 1; }
                        HoverButton {
                            text: "Refresh";
                            clicked => {
                                root.system_mode_auto_refresh_enabled = true;
                                root.display_mode_auto_refresh_enabled = true;
                                root.led_control_auto_refresh_enabled = true;
                                root.refresh();
                            }
                        }
                    }
                }

                VerticalBox {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: root.app_background_color;

                        tab_content := Rectangle {
                            x: 0px;
                            y: 0px;
                            width: min(parent.width, 1728px);
                            height: min(parent.height, 1080px);
                            background: root.app_background_color;

                            if root.active_tab == AppTab.system_mode : HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                spacing: 8px;

                                SystemModeTab {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    cpu-fan-rpm: root.cpu_fan_rpm;
                                    gpu-fan-rpm: root.gpu_fan_rpm;
                                    default-text-color: root.app_text_color;
                                }

                                HardwareStatsColumn {
                                    cpu-frequency: root.cpu_frequency;
                                    cpu-load-percent: root.cpu_load_percent;
                                    cpu-load-fill: root.cpu_load_fill;
                                    gpu-frequency: root.gpu_frequency;
                                    gpu-load-percent: root.gpu_load_percent;
                                    gpu-load-fill: root.gpu_load_fill;
                                    memory-usage: root.memory_usage;
                                    memory-percent: root.memory_percent;
                                    memory-fill: root.memory_fill;
                                    storage-usage: root.storage_usage;
                                    storage-percent: root.storage_percent;
                                    storage-fill: root.storage_fill;
                                }
                            }

                            if root.active_tab == AppTab.led_control : KeyboardTab {
                                width: parent.width;
                                height: parent.height;
                                active_zone: root.active_zone;
                                brightness <=> root.brightness;
                                brightness_slider <=> root.brightness_slider;
                                red <=> root.red;
                                green <=> root.green;
                                blue <=> root.blue;
                                color_hue <=> root.color_hue;
                                color_saturation <=> root.color_saturation;
                                applied_left_color: root.applied_left_color;
                                applied_middle_color: root.applied_middle_color;
                                applied_right_color: root.applied_right_color;
                                applied_bias_color: root.applied_bias_color;

                                select_zone(zone) => { root.select_zone(zone); }
                                brightness_slider_changed(value) => {
                                    if root.suppress_led_edit_events == false {
                                        root.led_control_auto_refresh_enabled = false;
                                        root.brightness_slider_changed(value);
                                    }
                                }
                                color_wheel_changed(x, y) => {
                                    if root.suppress_led_edit_events == false {
                                        root.led_control_auto_refresh_enabled = false;
                                        root.color_wheel_changed(x, y);
                                    }
                                }
                                apply_led_settings => {
                                    root.apply_led_settings();
                                    root.led_control_auto_refresh_enabled = true;
                                }
                            }

                            if root.active_tab == AppTab.display_mode : HorizontalBox {
                                width: parent.width;
                                height: parent.height;
                                spacing: 8px;

                                GpuTab {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    gpu_mode: root.gpu_mode;
                                    display-mode-warning: root.display_mode_warning;
                                    cpu-fan-rpm: root.cpu_fan_rpm;
                                    gpu-fan-rpm: root.gpu_fan_rpm;
                                    default-text-color: root.app_text_color;
                                    set_gpu_mode(mode) => { root.set_gpu_mode(mode); }
                                }

                                HardwareStatsColumn {
                                    cpu-frequency: root.cpu_frequency;
                                    cpu-load-percent: root.cpu_load_percent;
                                    cpu-load-fill: root.cpu_load_fill;
                                    gpu-frequency: root.gpu_frequency;
                                    gpu-load-percent: root.gpu_load_percent;
                                    gpu-load-fill: root.gpu_load_fill;
                                    memory-usage: root.memory_usage;
                                    memory-percent: root.memory_percent;
                                    memory-fill: root.memory_fill;
                                    storage-usage: root.storage_usage;
                                    storage-percent: root.storage_percent;
                                    storage-fill: root.storage_fill;
                                }
                            }

                            if root.active_tab == AppTab.about : AboutTab {
                                width: parent.width;
                                height: parent.height;
                                items: root.main_items;
                                credit_items: root.credit_items;
                                default-text-color: root.app_text_color;
                            }
                        }
                    }

                    Rectangle {
                        height: 34px;
                        horizontal-stretch: 1;
                        background: #111820;
                        border-width: 1px;
                        border-color: #2f3a46;

                        HorizontalBox {
                            x: 12px;
                            width: max(parent.width - 24px, 0px);
                            height: parent.height;
                            padding: 0px;
                            alignment: space-between;

                            HorizontalBox {
                                padding: 0px;
                                spacing: 4px;

                                Text {
                                    vertical-alignment: center;
                                    color: #a3aab3;
                                    font-size: 14px;
                                    text: "Made by";
                                }

                                Rectangle {
                                    height: parent.height;
                                    min-width: author_text.min-width;
                                    preferred-width: author_text.preferred-width;
                                    horizontal-stretch: 0;

                                    author_text := Text {
                                        height: parent.height;
                                        vertical-alignment: center;
                                        color: author_touch.has-hover ? white : #a3aab3;
                                        font-size: 14px;
                                        font-weight: author_touch.has-hover ? 700 : 400;
                                        text: "Mert Kurttutan";
                                    }

                                    author_touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { Platform.open-url("https://github.com/mert-kurttutan"); }
                                    }
                                }
                            }

                            Text {
                                vertical-alignment: center;
                                color: #a3aab3;
                                font-size: 14px;
                                text: "v" + root.app_version;
                            }
                        }
                    }
                }
            }
        }
    }
}
